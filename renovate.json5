{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
"config:recommended"
  ],
  "packageRules": [
    {
      "versioning": "regex:^(?<compatibility>.*(\d+\.)?)(?<major>\d+)\.(?<minor>\d+)\.(?<patch>\d+)?$",
      "matchPackageNames": [
        "/^lscr.io\/linuxserver\//"
      ]
    },
    {
      "versioning": "regex:^(?<compatibility>.*(\d+\.)?)(?<major>\d+)\.(?<minor>\d+)\.(?<patch>\d+)?$",
      "allowedVersions": "/^(\d{1,3}\.)(\d*\.)*\d*$/",
      "matchPackageNames": [
        "/^linuxserver\/overseerr/"
      ]
    },
    {
      "versioning": "regex:^(?<compatibility>.*(\d+\.)?)(?<major>\d+)\.(?<minor>\d+)\.(?<patch>\d+)?$",
      "allowedVersions": "/^(\d{1,3}\.)(\d*\.)*\d*$/",
      "matchPackageNames": [
        "/^linuxserver\/tautulli/"
      ]
    },
    {
      "versioning": "regex:^(?<compatibility>.*(\d+\.)?)(?<major>\d+)\.(?<minor>\d+)\.(?<patch>\d+)-(ls(?<build>\d+))?$",
      "matchPackageNames": [
        "/^lscr.io\/linuxserver-labs\/plextraktsync/"
      ]
    },
    {
      "versioning": "regex:^(?<major>\d+)\.(?<minor>\d+)\.(?<patch>\d+)-nbxyz(?<digest>\d+)$",
      "matchPackageNames": [
        "/^ghcr\.io\/netbootxyz\/netbootxyz/"
      ]
    },
    {
      "versioning": "regex:^(?<compatibility>.*(\d+\.)?)(?<major>\d+)\.(?<minor>\d+)\.(?<patch>\d+)?$",
      "allowedVersions": "/^(\d{1,2}\.)(\d*\.)*\d*$/",
      "matchPackageNames": [
        "/^linuxserver\/deluge/"
      ]
    },
    {
      "versioning": "regex:^(?<compatibility>.*(\d+\.)?)(?<major>\d+)\.(?<minor>\d+)\.(?<patch>\d+)?$",
      "matchPackageNames": [
        "/^linuxserver\/jellyfin/"
      ]
    },
    {
      "versioning": "regex:^(?<compatibility>.*(\d+\.)?)(?<major>\d+)\.(?<minor>\d+)\.(?<patch>\d+)?$",
      "allowedVersions": "/^(\d{1,3}\.)(\d*\.)*\d{1,3}$/",
      "matchPackageNames": [
        "/^linuxserver\/changedetection.io/"
      ]
    }
  ]
}
